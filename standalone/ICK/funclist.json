      "args": {
        "action": {
          "type": "static",
          "value": "SwitchToEraser",
          "description": "操作指令"
        }
      },
      "returns": [
        ["status", "状态（Successful/Error）"]
      ]
    },
    "SwitchToCursor": {
      "appID": "0x00000031",
      "openSocketID": "0x00000021",
      "description": "切换到光标/选择模式（隐藏墨迹画布）",
