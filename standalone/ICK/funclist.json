      ]
    },
    "DrawFunction": {
      "appID": "0x00000031",
      "openSocketID": "0x00000021",
      "description": "绘制函数图像 (y=f(x))",
      "args": {
        "action": {
          "type": "static",
          "value": "DrawFunction",
          "description": "操作指令"
        },
        "expression": {
          "type": "input",
          "defaultVal": "sin(x)",
          "description": "数学表达式，支持 LaTeX"
        },
        "xMin": {
          "type": "input",
          "defaultVal": "-6.28",
          "description": "x 最小值"
        },
        "xMax": {
          "type": "input",
          "defaultVal": "6.28",
          "description": "x 最大值"
        },
        "step": {
          "type": "input",
          "defaultVal": "0.05",
          "description": "采样步长 (越小越平滑)"
        },
        "offsetX": {
          "type": "input",
          "defaultVal": "0",
          "description": "原点 X 像素偏移 (相对画布中心)"
        },
        "offsetY": {
          "type": "input",
          "defaultVal": "0",
          "description": "原点 Y 像素偏移 (相对画布中心, 正=上)"
        }
      },
      "returns": [
        ["status", "状态（Successful/Error）"]
      ]
    }
