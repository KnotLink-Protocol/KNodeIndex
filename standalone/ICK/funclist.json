{
  "appName": "Ink Canvas",
  "specVersion": "1.0",
  "manifestVersion": "1.0.0",
  "openSocket": {
    "GetStatus": {
      "appID": "0x00000031",
      "openSocketID": "0x00000021",
      "description": "获取 Ink Canvas 当前状态",
      "args": {
        "action": {
          "type": "static",
          "value": "GetStatus",
          "description": "操作指令"
        }
      },
      "returns": [
        ["status", "状态（Successful/Error）"],
        ["visible", "墨迹画布可见状态（true/false）"],
        ["isPenMode", "是否为笔模式（true/false）"],
        ["isEraserMode", "是否为橡皮擦模式（true/false）"]
      ]
    },
    "GetVersion": {
      "appID": "0x00000031",
      "openSocketID": "0x00000021",
      "description": "获取 Ink Canvas 版本信息",
      "args": {
        "action": {
          "type": "static",
          "value": "GetVersion",
          "description": "操作指令"
        }
      },
      "returns": [
        ["status", "状态（Successful/Error）"],
        ["version", "版本号"]
      ]
    },
    "SwitchToPen": {
      "appID": "0x00000031",
      "openSocketID": "0x00000021",
      "description": "切换到笔模式",
      "args": {
        "action": {
          "type": "static",
          "value": "SwitchToPen",
          "description": "操作指令"
        }
      },
      "returns": [
